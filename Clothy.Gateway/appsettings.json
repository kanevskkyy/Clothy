{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Yarp": "Information"
        }
    },
    "AllowedHosts": "*",
    "ReverseProxy": {
        "Routes": {
            "catalog-route": {
                "ClusterId": "catalog-cluster",
                "Match": { "Path": "/api/catalog/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "catalog-team",
                    "priority": "high",
                    "rateLimit": "100"
                }
            },
            "orders-route": {
                "ClusterId": "orders-cluster",
                "Match": { "Path": "/api/orders/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/orders/{**catch-all}" } ],
                "Metadata": {
                    "version": "v2",
                    "team": "orders-team",
                    "priority": "medium",
                    "rateLimit": "50"
                }
            },
            "users-route": {
                "ClusterId": "users-cluster",
                "Match": { "Path": "/api/users/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/users/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "users-team",
                    "priority": "medium",
                    "rateLimit": "50"
                }
            },
            "baskets-route": {
                "ClusterId": "basket-cluster",
                "Match": { "Path": "/api/basket/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/basket/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "basket-team",
                    "priority": "medium",
                    "rateLimit": "50"
                }
            },
            "keycloak-route": {
                "ClusterId": "keycloak-cluster",
                "Match": { "Path": "/auth/{**catch-all}" },
                "Transforms": [
                    { "PathRemovePrefix": "/auth" }
                ],
                "Metadata": {
                    "version": "v1",
                    "team": "identity-team",
                    "priority": "high",
                    "rateLimit": "10"
                }
            }
        },
        "Clusters": {
            "catalog-cluster": {
                "Destinations": { "catalog-destination": { "Address": "https://localhost:5001" } }
            },
            "orders-cluster": {
                "Destinations": { "orders-destination": { "Address": "https://localhost:5002" } }
            },
            "users-cluster": {
                "Destinations": { "users-destination": { "Address": "https://localhost:5005" } }
            },
            "basket-cluster": {
                "Destinations": { "basket-destination": { "Address": "https://localhost:5006" } }
            },
            "keycloak-cluster": {
                "Destinations": { "keycloak-destination": { "Address": "http://localhost:8080" } },
                "HttpClient": { "DangerousAcceptAnyServerCertificateValidator": true }
            }
        }
    }
}