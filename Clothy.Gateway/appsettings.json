{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Yarp": "Information"
        }
    },
    "AllowedHosts": "*",
    "ReverseProxy": {
      "Routes": {
        "catalog-route": {
          "ClusterId": "catalog-cluster",
          "Match": {
            "Path": "/api/catalog/{**catch-all}"
          },
          "Transforms": [
            {
              "PathPattern": "/api/catalog/{**catch-all}"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "catalog-team",
            "priority": "high",
            "rateLimit": "100"
          }
        },
        "payment-route": {
          "ClusterId": "payment-cluster",
          "Match": {
            "Path": "/api/payments/{**catch-all}"
          },
          "Transforms": [
            {
              "PathPattern": "/api/payments/{**catch-all}"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "payments-team",
            "priority": "high",
            "rateLimit": "100"
          }
        },

        "orders-route": {
          "ClusterId": "orders-cluster",
          "Match": {
            "Path": "/api/orders/{**catch-all}"
          },
          "Transforms": [
            {
              "PathPattern": "/api/orders/{**catch-all}"
            }
          ],
          "Metadata": {
            "version": "v2",
            "team": "orders-team",
            "priority": "medium",
            "rateLimit": "50"
          }
        },
        "basket-route": {
          "ClusterId": "basket-cluster",
          "Match": {
            "Path": "/api/basket/{**catch-all}"
          },
          "Transforms": [
            {
              "PathPattern": "/api/basket/{**catch-all}"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "basket-team",
            "priority": "medium",
            "rateLimit": "50"
          }
        },
        "auth-route": {
          "ClusterId": "auth-cluster",
          "Match": {
            "Path": "/api/auth/{**catch-all}"
          },
          "Transforms": [
            {
              "PathPattern": "/api/auth/{**catch-all}"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "auth-team",
            "priority": "high",
            "rateLimit": "50"
          }
        },
        "users-route": {
          "ClusterId": "auth-cluster",
          "Match": {
            "Path": "/api/users/{**catch-all}"
          },
          "Transforms": [
            {
              "PathPattern": "/api/users/{**catch-all}"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "auth-team",
            "priority": "medium",
            "rateLimit": "50"
          }
        },
        "reviews-route": {
          "ClusterId": "reviews-cluster",
          "Match": {
            "Path": "/api/reviews/{**catch-all}"
          },
          "Transforms": [
            {
              "PathPattern": "/api/reviews/{**catch-all}"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "reviews-team",
            "priority": "medium",
            "rateLimit": "50"
          }
        },
        "questions-route": {
          "ClusterId": "reviews-cluster",
          "Match": {
            "Path": "/api/questions/{**catch-all}"
          },
          "Transforms": [
            {
              "PathPattern": "/api/questions/{**catch-all}"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "reviews-team",
            "priority": "medium",
            "rateLimit": "50"
          }
        },
        "clothe-route": {
          "ClusterId": "aggregator-cluster",
          "Match": {
            "Path": "/api/clothe/{**catch-all}"
          },
          "Transforms": [
            {
              "PathPattern": "/api/clothe/{**catch-all}"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "aggregator-team",
            "priority": "medium",
            "rateLimit": "100"
          }
        },
        "filters-route": {
          "ClusterId": "aggregator-cluster",
          "Match": {
            "Path": "/api/filters/{**catch-all}"
          },
          "Transforms": [
            {
              "PathPattern": "/api/filters/{**catch-all}"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "aggregator-team",
            "priority": "medium",
            "rateLimit": "100"
          }
        },
        "aggregator-route": {
          "ClusterId": "aggregator-cluster",
          "Match": {
            "Path": "/api/aggregator/{**catch-all}"
          },
          "Transforms": [
            {
              "PathRemovePrefix": "/api/aggregator"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "aggregator-team",
            "priority": "high",
            "rateLimit": "100"
          }
        },
        "keycloak-route": {
          "ClusterId": "keycloak-cluster",
          "Match": {
            "Path": "/keycloak/{**catch-all}"
          },
          "Transforms": [
            {
              "PathRemovePrefix": "/keycloak"
            }
          ],
          "Metadata": {
            "version": "v1",
            "team": "identity-team",
            "priority": "high",
            "rateLimit": "100"
          }
        }
      },
      "Clusters": {
        "catalog-cluster": {
          "Destinations": {
            "catalog-destination": {
              "Address": "https://localhost:5001"
            }
          }
        },
        "orders-cluster": {
          "Destinations": {
            "orders-destination": {
              "Address": "https://localhost:5002"
            }
          }
        },
        "basket-cluster": {
          "Destinations": {
            "basket-destination": {
              "Address": "https://localhost:5006"
            }
          }
        },
        "auth-cluster": {
          "Destinations": {
            "auth-destination": {
              "Address": "https://localhost:5005"
            }
          }
        },
        "reviews-cluster": {
          "Destinations": {
            "reviews-destination": {
              "Address": "https://localhost:5003"
            }
          }
        },
        "payment-cluster": {
          "Destinations": {
            "payments-destination": {
              "Address": "https://localhost:5008"
            }
          }
        },
        "aggregator-cluster": {
          "Destinations": {
            "aggregator-destination": {
              "Address": "https://localhost:5004"
            }
          }
        },
        "keycloak-cluster": {
          "Destinations": {
            "keycloak-destination": {
              "Address": "http://localhost:8080"
            }
          },
          "HttpClient": {
            "DangerousAcceptAnyServerCertificateValidator": true
          }
        }
      }
    }
}