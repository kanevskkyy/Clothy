{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning",
            "Yarp": "Information"
        }
    },
    "AllowedHosts": "*",
    "ReverseProxy": {
        "Routes": {
            "catalog-route": {
                "ClusterId": "catalog-cluster",
                "Match": { "Path": "/api/catalog/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "catalog-team",
                    "priority": "high",
                    "rateLimit": "100"
                }
            },
            "orders-route": {
                "ClusterId": "orders-cluster",
                "Match": { "Path": "/api/orders/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/orders/{**catch-all}" } ],
                "Metadata": {
                    "version": "v2",
                    "team": "orders-team",
                    "priority": "medium",
                    "rateLimit": "50"
                }
            },
            "cities-route": {
                "ClusterId": "orders-cluster",
                "Match": { "Path": "/api/cities/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/cities/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "orders-team",
                    "priority": "low",
                    "rateLimit": "50"
                }
            },
            "regions-route": {
                "ClusterId": "orders-cluster",
                "Match": { "Path": "/api/regions/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/regions/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "orders-team",
                    "priority": "low",
                    "rateLimit": "50"
                }
            },
            "settlements-route": {
                "ClusterId": "orders-cluster",
                "Match": { "Path": "/api/settlements/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/settlements/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "orders-team",
                    "priority": "low",
                    "rateLimit": "50"
                }
            },
            "delivery-providers-route": {
                "ClusterId": "orders-cluster",
                "Match": { "Path": "/api/delivery-providers/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/delivery-providers/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "orders-team",
                    "priority": "low",
                    "rateLimit": "50"
                }
            },
            "pickup-points-route": {
                "ClusterId": "orders-cluster",
                "Match": { "Path": "/api/pickup-points/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/pickup-points/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "orders-team",
                    "priority": "low",
                    "rateLimit": "50"
                }
            },
            "order-statuses-route": {
                "ClusterId": "orders-cluster",
                "Match": { "Path": "/api/order-statuses/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/order-statuses/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "orders-team",
                    "priority": "low",
                    "rateLimit": "50"
                }
            },
            "reviews-route": {
                "ClusterId": "reviews-cluster",
                "Match": { "Path": "/api/reviews/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/reviews/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "reviews-team",
                    "priority": "low",
                    "rateLimit": "20"
                }
            },
            "questions-route": {
                "ClusterId": "reviews-cluster",
                "Match": { "Path": "/api/questions/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/questions/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "reviews-team",
                    "priority": "low",
                    "rateLimit": "20"
                }
            },
            "aggregator-route": {
                "ClusterId": "aggregator-cluster",
                "Match": { "Path": "/api/aggregator/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "aggregator-team",
                    "priority": "high",
                    "rateLimit": "80"
                }
            },
            "auth-route": {
                "ClusterId": "users-cluster",
                "Match": { "Path": "/api/auth/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/auth/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "users-team",
                    "priority": "high",
                    "rateLimit": "50"
                }
            },
            "users-route": {
                "ClusterId": "users-cluster",
                "Match": { "Path": "/api/users/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/users/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "users-team",
                    "priority": "medium",
                    "rateLimit": "50"
                }
            },
            "baskets-route": {
                "ClusterId": "basket-cluster",
                "Match": { "Path": "/api/basket/{**catch-all}" },
                "Transforms": [ { "PathPattern": "/api/basket/{**catch-all}" } ],
                "Metadata": {
                    "version": "v1",
                    "team": "basket-team",
                    "priority": "medium",
                    "rateLimit": "50"
                }
            }
        },
        "Clusters": {
            "catalog-cluster": {
                "Destinations": { "catalog-destination": { "Address": "https://localhost:5001" } }
            },
            "orders-cluster": {
                "Destinations": { "orders-destination": { "Address": "https://localhost:5002" } }
            },
            "reviews-cluster": {
                "Destinations": { "reviews-destination": { "Address": "https://localhost:5003" } }
            },
            "aggregator-cluster": {
                "Destinations": { "aggregator-destination": { "Address": "https://localhost:5004" } }
            },
            "users-cluster": {
                "Destinations": { "users-destination": { "Address": "https://localhost:5005" } }
            },
            "basket-cluster": {
                "Destinations": { "basket-destination": { "Address": "https://localhost:5006" } }
            }
        }
    }
}