@using Clothy.Shared.Events.EmailEvents.ClotheStockUpdated
@model ClotheStockUpdatedEvent
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clothy - Item Back in Stock</title>
</head>
<body style="margin: 0; padding: 0; font-family: Arial, Helvetica, sans-serif; background-color: #f3f4f6;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color: #f3f4f6;">
        <tr>
            <td style="padding: 20px 0;">
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="700" style="margin: 0 auto; background-color: #ffffff; border-radius: 14px; max-width: 100%;">
                    <tr>
                        <td style="padding: 25px 25px 20px 25px;">
                            <h1 style="margin: 0; font-size: 26px; font-weight: 700; color: #111111;">Clothy</h1>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding: 0 25px 20px 25px;">
                            <p style="margin: 0; font-size: 16px; color: #111111;">
                                Dear <strong>@Model.UserFirstName</strong>,
                            </p>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding: 0 25px 30px 25px;">
                            <p style="margin: 0 0 15px 0; font-size: 16px; color: #374151; line-height: 1.6;">
                                Great news! The item you subscribed to is back in stock:
                            </p>
                            <div style="background-color: #f9fafb; border-left: 4px solid #111111; padding: 20px; border-radius: 8px; margin: 20px 0;">
                                <p style="margin: 0 0 8px 0; font-size: 18px; font-weight: 600; color: #111111;">
                                    @Model.ClotheName
                                </p>
                                <p style="margin: 0; font-size: 15px; color: #6b7280;">
                                    Size: <strong>@Model.Size</strong> | Color: <strong>@Model.Color</strong>
                                </p>
                            </div>
                            <p style="margin: 15px 0 0 0; font-size: 16px; color: #374151; line-height: 1.6;">
                                Hurry up! The item is now available for purchase.
                            </p>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding: 0 25px 40px 25px; text-align: center;">
                            <a href="http://localhost:5173/clothe/@Model.ClotheSlug/@Model.ColorSlug" style="display: inline-block; background-color: #111111; color: #ffffff; text-decoration: none; padding: 14px 40px; border-radius: 8px; font-size: 16px; font-weight: 600;">
                                View Product
                            </a>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding: 30px 25px 25px 25px; text-align: center; border-top: 1px solid #e5e7eb;">
                            <p style="margin: 0; font-size: 14px; color: #6b7280; line-height: 1.5;">
                                Stay stylish,<br>
                                — The Clothy Team <span style="font-size: 12px;">🖤</span>
                            </p>
                        </td>
                    </tr>

                    <tr>
                        <td style="padding: 0 25px 25px 25px; text-align: center;">
                            <p style="margin: 0; font-size: 12px; color: #9ca3af; line-height: 1.5;">
                                You received this email because you subscribed to a stock notification for this item.<br>
                                This is a one-time notification and your subscription has been automatically removed.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>